# =============================================================================
# LeadSaaS — Environment Variables
# Copy to .env.local and fill in your values
# =============================================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (AI Agent Engine)
ANTHROPIC_API_KEY=sk-ant-your-key

# Stripe (Billing)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_PRICE_STARTER_MONTHLY=price_1T9doWDKlxdQW6LVwMpDzqvS
STRIPE_PRICE_STARTER_ANNUAL=price_1T9doWDKlxdQW6LVwMpDzqvS
STRIPE_PRICE_GROWTH_MONTHLY=price_1T9doyDKlxdQW6LV3rR7qjsj
STRIPE_PRICE_GROWTH_ANNUAL=price_1T9doyDKlxdQW6LV3rR7qjsj
STRIPE_PRICE_SCALE_MONTHLY=price_1T9dpDDKlxdQW6LVhUB7vSAe
STRIPE_PRICE_SCALE_ANNUAL=price_1T9dpDDKlxdQW6LVhUB7vSAe

# Twilio (SMS/Voice)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_DEFAULT_NUMBER=+15551234567

# Resend (Email)
RESEND_API_KEY=re_your-key
RESEND_WEBHOOK_SECRET=your-webhook-secret
RESEND_FROM_DOMAIN=notifications.leadsandsaas.com

# Sentry (Error Monitoring)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/xxx
